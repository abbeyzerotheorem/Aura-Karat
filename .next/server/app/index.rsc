2:T1e4d,{"@context":"https://schema.org","@type":"JewelryStore","name":"Aura & Karat","description":"Aura & Karat is a flagship atelier crafting bespoke and ready-to-wear fine jewelry from ethically recycled precious metals and GIA-certified conflict-free diamonds. Each piece is hand-finished by master bench jewelers in our Madison Avenue workshop.","url":"https://auraandkarat.com","telephone":"+1 (212) 555-0147","email":"concierge@auraandkarat.com","address":{"@type":"PostalAddress","streetAddress":"742 Madison Avenue, Suite 12","addressLocality":"New York, NY 10065","addressCountry":"US"},"geo":{"@type":"GeoCoordinates","latitude":40.7736,"longitude":-73.9662},"openingHoursSpecification":[{"@type":"OpeningHoursSpecification","dayOfWeek":"Monday","opens":"10:00 AM","closes":"6:00 PM"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Tuesday","opens":"10:00 AM","closes":"7:00 PM"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Wednesday","opens":"10:00 AM","closes":"7:00 PM"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Thursday","opens":"10:00 AM","closes":"7:00 PM"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Friday","opens":"10:00 AM","closes":"8:00 PM"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Saturday","opens":"11:00 AM","closes":"6:00 PM"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Sunday","opens":"By Private Appointment","closes":"18:00"}],"priceRange":"$$$$","image":"https://images.unsplash.com/photo-1605100804763-247d67f77de9?w=1200&h=630&fit=crop&q=85","hasOfferCatalog":{"@type":"OfferCatalog","name":"Aura & Karat Collection","itemListElement":[{"@type":"Offer","position":1,"itemOffered":{"@type":"Product","name":"Elara Solitaire Ring","description":"A cathedral-set solitaire featuring a knife-edge band that draws the eye to a brilliant-cut center stone. Hand-polished prongs and a hidden halo whisper luxury without spectacle.","image":"https://images.unsplash.com/photo-1605100804763-247d67f77de9?w=800&h=1000&fit=crop&q=85","s