y.","image":"https://images.unsplash.com/photo-1603561591411-07134e71a2a9?w=800&h=1000&fit=crop&q=85","sku":"ak-aurora-band","brand":{"@type":"Brand","name":"Aura & Karat"},"material":"14k Yellow Gold","category":"Fine Rings","offers":{"@type":"Offer","price":2750,"priceCurrency":"USD","availability":"https://schema.org/InStock","seller":{"@type":"Organization","name":"Aura & Karat"}},"additionalProperty":[{"@type":"PropertyValue","name":"Metal Option","value":"14k Yellow Gold"},{"@type":"PropertyValue","name":"Metal Option","value":"18k Rose Gold"},{"@type":"PropertyValue","name":"Metal Option","value":"Platinum"},{"@type":"PropertyValue","name":"Stone Option","value":"Lab-Grown Diamonds"},{"@type":"PropertyValue","name":"Stone Option","value":"Natural Diamonds"}]}},{"@type":"Offer","position":4,"itemOffered":{"@type":"Product","name":"Heritage Signet Ring","description":"A substantial cushion signet with softened edges and a hand-engraved face. Designed to be passed down, worn daily, and re-engraved for the next generation.","image":"https://images.unsplash.com/photo-1611652022418-a9419f74343d?w=800&h=1000&fit=crop&q=85","sku":"ak-heritage-signet","brand":{"@type":"Brand","name":"Aura & Karat"},"material":"14k Yellow Gold","category":"Fine Rings","offers":{"@type":"Offer","price":1950,"priceCurrency":"USD","availability":"https://schema.org/InStock","seller":{"@type":"Organization","name":"Aura & Karat"}},"additionalProperty":[{"@type":"PropertyValue","name":"Metal Option","value":"14k Yellow Gold"},{"@type":"PropertyValue","name":"Metal Option","value":"18k Yellow Gold"},{"@type":"PropertyValue","name":"Metal Option","value":"Platinum"},{"@type":"PropertyValue","name":"Stone Option","value":"Engraved Initials"},{"@type":"PropertyValue","name":"Stone Option","value":"Onyx Stone Inlay"}]}},{"@type":"Offer","position":5,"itemOffered":{"@type":"Product","name":"Lumière Drop Earrings","description":"Articulated drops that sway with quiet drama. Each pearl is matched f